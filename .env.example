# KisanMind Environment Variables
# Copy this file to .env and fill in your actual keys
# NEVER push .env to GitHub!

# Google AI Studio API Key
# Get it free at: https://aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# data.gov.in API Key (for Agmarknet mandi prices)
# Register free at: https://data.gov.in
DATA_GOV_API_KEY=your_data_gov_api_key_here

# ── Model + fallback config (optional — sensible defaults are built in) ──
# Primary text/chat model used by every agent.
# GEMINI_MODEL=gemini-3.5-flash
# Model CropDoc uses for image diagnosis (defaults to GEMINI_MODEL above).
# GEMINI_VISION_MODEL=gemini-3.5-flash

# Groq fallback: if this key is set, KisanMind will automatically retry a
# failed Gemini call on Groq instead of erroring out (e.g. if your Gemini
# key is rate-limited, out of quota, or briefly unreachable).
# Get a free key at: https://console.groq.com
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional: FastAPI backend URL (for Streamlit)
# Change if deploying backend separately
BACKEND_URL=http://localhost:8000
